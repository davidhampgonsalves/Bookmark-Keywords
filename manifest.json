{
  "manifest_version": 3,
  "name": "Bookmark Keywords",
  "version": "1.0.0",
  "description": "Quickly navigate to bookmarks from the omnibox using the \"-\" keyword.",
  "background": {
    "service_worker": "background.js"
  },
  "omnibox": {
    "keyword": "-"
  },
  "permissions": [
    "bookmarks",
    "storage"
  ],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
